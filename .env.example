# Database (local development)
DATABASE_URL=postgresql://user:password@localhost:5432/richmond_land
PGHOST=localhost
PGPORT=5432
PGDATABASE=richmond_land
PGUSER=user
PGPASSWORD=password

# Supabase (production)
SUPABASE_DB_HOST=db.XXXXXXXXXXXX.supabase.co
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.XXXXXXXXXXXX
SUPABASE_DB_PASSWORD=your_password_here
SUPABASE_DIRECT_URL=postgresql://postgres.XXXXXXXXXXXX:password@db.XXXXXXXXXXXX.supabase.co:5432/postgres

# API Keys (DO NOT commit real values)
MAPBOX_ACCESS_TOKEN=pk.your_token_here
REPLIERS_API_KEY=your_key_here

# App Config
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
API_HOST=0.0.0.0
